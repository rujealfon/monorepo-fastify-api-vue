{
  "name": "@monorepo-fastify-api-vue/root",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "nub run -r --parallel --aggregate-output dev",
    "build": "nub run -r build",
    "start": "nub run --filter @monorepo-fastify-api-vue/api start",
    "test": "nub run -r --parallel test",
    "test:e2e": "nub run --filter @monorepo-fastify-api-vue/web test:e2e",
    "test:unit": "nub run --filter @monorepo-fastify-api-vue/api test:unit",
    "lint": "nub run -r --parallel lint",
    "lint:fix": "nub run -r --parallel lint:fix",
    "db:generate": "nub run --filter @monorepo-fastify-api-vue/api db:generate",
    "db:migrate": "nub run --filter @monorepo-fastify-api-vue/api db:migrate",
    "db:seed": "nub run --filter @monorepo-fastify-api-vue/api db:seed",
    "db:studio": "nub run --filter @monorepo-fastify-api-vue/api db:studio",
    "clean": "nub run clean:deps && nub run clean:dist",
    "clean:deps": "rm -rf node_modules apps/*/node_modules packages/*/node_modules",
    "clean:dist": "rm -rf apps/*/dist packages/*/dist"
  },
  "devDependencies": {
    "typescript": "^5.9.3"
  }
}
